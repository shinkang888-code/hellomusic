# Neon PostgreSQL 연결 문자열 (pooler 권장)
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Gemini (학원상담 AI — 없으면 키워드 fallback)
GEMINI_API_KEY=""

# Google OAuth (학원정보 관리자 로그인)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# 쉼표로 구분 — 원장 Google 이메일
ACADEMY_ADMIN_EMAILS="director@example.com"

# 세션 서명 (미설정 시 GOOGLE_CLIENT_SECRET 사용)
AUTH_SECRET=""

# HelloManager(helloap) SSO — helloap Vercel과 동일 값
HELLO_SSO_SECRET=""
NEXT_PUBLIC_HELLO_MANAGER_URL="https://helloappbeta.vercel.app"
NEXT_PUBLIC_SITE_URL="https://lc-aca.vercel.app"
